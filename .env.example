# App
APP_ENV=development
APP_NAME=GoPinion Outbound OS
APP_URL=http://localhost:3000
# Set to `postgres` to enable the Supabase-backed repository path.
DATA_BACKEND=mock

# Database
# Optional direct Postgres URL for future tooling or migration workflows.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gopinion_outbound_os
# Required when DATA_BACKEND=postgres.
SUPABASE_URL=
# Required when DATA_BACKEND=postgres.
SUPABASE_SERVICE_ROLE_KEY=
# The first persistence tranche targets the public schema.
SUPABASE_DB_SCHEMA=public

# AI
OPENAI_API_KEY=

# Placeholder providers for v1 scaffolding
ENRICHMENT_PROVIDER=mock
EMAIL_PROVIDER=mock
CALENDAR_PROVIDER=mock
CRM_PROVIDER=mock
ANALYTICS_PROVIDER=mock
