# App
APP_ENV=development
APP_NAME=GoPinion Outbound OS
APP_URL=http://localhost:3000
# Set to `postgres` to enable the Supabase-backed repository path.
DATA_BACKEND=mock

# Database
# Optional direct Postgres URL for future tooling or migration workflows.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gopinion_outbound_os
# Required when DATA_BACKEND=postgres.
SUPABASE_URL=
# Required when DATA_BACKEND=postgres.
SUPABASE_SERVICE_ROLE_KEY=
# The first persistence tranche targets the public schema.
SUPABASE_DB_SCHEMA=public

# AI
OPENAI_API_KEY=

# Provider switches
ENRICHMENT_PROVIDER=basic
WEBSITE_DISCOVERY_PROVIDER=open_web
EMAIL_PROVIDER=mock
CALENDAR_PROVIDER=mock
CRM_PROVIDER=mock
ANALYTICS_PROVIDER=mock

# Optional Scrapling worker settings when ENRICHMENT_PROVIDER=scrapling.
SCRAPLING_WORKER_TRANSPORT=auto
SCRAPLING_WORKER_ENDPOINT=/api/enrichment/scrapling
SCRAPLING_WORKER_ORIGIN=http://localhost:3000
SCRAPLING_PYTHON_BIN=python3
SCRAPLING_WORKER_ENTRY=workers/enrichment/main.py
SCRAPLING_WORKER_TIMEOUT_MS=20000
